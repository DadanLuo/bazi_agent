  "congge": {
    "description": "从格",
    "rules": [
      {
        "name": "从强格",
        "condition": "日主极旺，满盘印比，无克泄耗",
        "min_strength_score": 80,
        "description": "日主强旺至极，宜顺其势"
      },
      {
        "name": "从弱格",
        "condition": "日主极弱，满盘克泄耗，无印比帮扶",
        "max_strength_score": 20,
        "description": "日主衰弱至极，宜从其弱"
      },
      {
        "name": "从财格",
        "condition": "财星极旺，日主弱极无根",
        "min_cai_score": 60,
        "max_day_master_score": 25,
        "description": "满盘财星，日主无从，宜从财"
      },
      {
        "name": "从杀格",
        "condition": "官杀极旺，日主弱极无根",
        "min_sha_score": 60,
        "max_day_master_score": 25,
        "description": "满盘官杀，日主无从，宜从杀"
      },
      {
        "name": "从儿格",
        "condition": "食伤极旺，日主弱极无根",
        "min_shishang_score": 60,
        "max_day_master_score": 25,
        "description": "满盘食伤，日主无从，宜从儿"
      }
    ]
  },
  "zage": {
    "description": "杂格（特殊格局）",
    "rules": [
      {
        "name": "化气格",
        "condition": "日干与时干或月干合化成功",
        "description": "天干五合化气成功"
      },
      {
        "name": "魁罡格",
        "condition": "日柱为庚辰、庚戌、壬辰、戊戌",
        "rizhu": ["庚辰", "庚戌", "壬辰", "戊戌"],
        "description": "魁罡日出生，性格刚强"
      },
      {
        "name": "金神格",
        "condition": "时柱为乙丑、己巳、癸酉",
        "shizhu": ["乙丑", "己巳", "癸酉"],
        "description": "金神入火乡，富贵天下响"
      },
      {
        "name": "日德格",
        "condition": "日柱为甲寅、丙辰、戊辰、庚辰、壬戌",
        "rizhu": ["甲寅", "丙辰", "戊辰", "庚辰", "壬戌"],
        "description": "日德坐命，为人慈善"
      },
      {
        "name": "日贵格",
        "condition": "日柱为丁酉、丁亥、癸巳、癸卯",
        "rizhu": ["丁酉", "丁亥", "癸巳", "癸卯"],
        "description": "日贵坐命，主富贵"
      },
      {
        "name": "禄刃格",
        "condition": "日主得禄或得刃",
        "description": "建禄羊刃，身旺可任财官"
      }
    ]
  }
