      },
      {
        "name": "害太岁",
        "condition": "流年地支与出生年地支相害",
        "effect": "陷害，多小人",
        "severity": "轻"
      },
      {
        "name": "破太岁",
        "condition": "流年地支与出生年地支相破",
        "effect": "破坏，多损耗",
        "severity": "轻"
      },
      {
        "name": "合太岁",
        "condition": "流年地支与出生年地支相合",
        "effect": "和合，多机遇",
        "severity": "吉"
      }
    ]
  },
